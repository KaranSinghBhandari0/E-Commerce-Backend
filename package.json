{
  "name": "e-commerce-backend",
  "version": "1.0.0",
  "description": "Production-grade E-Commerce Backend built with Express.js and TypeScript",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KaranSinghBhandari0/E-Commerce-Backend.git"
  },
  "keywords": [
    "express",
    "typescript",
    "nodejs",
    "backend",
    "ecommerce"
  ],
  "author": "Karan Singh Bhandari",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/KaranSinghBhandari0/E-Commerce-Backend/issues"
  },
  "homepage": "https://github.com/KaranSinghBhandari0/E-Commerce-Backend#readme",
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
{
  "name": "e-commerce-backend",
  "version": "1.0.0",
  "description": "Production-grade E-Commerce Backend built with Express.js and TypeScript",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && node scripts/post-build.ts",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit && node scripts/post-type-check.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write . && tsx scripts/post-format.ts",
    "format:check": "prettier --check . && tsx scripts/post-format-check.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KaranSinghBhandari0/E-Commerce-Backend.git"
  },
  "keywords": [
    "express",
    "typescript",
    "nodejs",
    "backend",
    "ecommerce"
  ],
  "author": "Karan Singh Bhandari",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/KaranSinghBhandari0/E-Commerce-Backend/issues"
  },
  "homepage": "https://github.com/KaranSinghBhandari0/E-Commerce-Backend#readme",
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.7.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.39.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
